# ─── Frontend (Vercel) ────────────────────────────────────────────────────────
# Set this in the Vercel dashboard as NEXT_PUBLIC_API_URL
# It must point to your deployed FastAPI backend (e.g. on Railway / Render / Fly.io)
NEXT_PUBLIC_API_URL=https://your-api-host.example.com

# ─── Backend (FastAPI server) ─────────────────────────────────────────────────
# Enable live LLM calls. Set to "true" for production with real AI evaluation.
# Set to "false" to force seeded/rule-based fallback (no API keys required).
ENABLE_EXTERNAL_API_CALLS=true

# Required when ENABLE_EXTERNAL_API_CALLS=true
# Used by: rubric_scorer (gemini-2.0-flash), diligence_generator (gemini-2.0-flash),
#          risk_detector secondary pass (gemini-2.0-flash)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...
